{
  "$schema": "https://opencode.ai/config.json",
  "context": [
    ".agents/workflows/mustfollow.md",
    ".agents/AGENTS.md"
  ],
  "cron": [
    {
      "name": "dependabot-daily-scan",
      "schedule": "0 3 * * *",
      "command": "gh pr list --author dependabot[bot] --state open --json number,title,headRefName --jq '.[] | select(.headRefName | startswith(\"dependabot\")) | .number' | ForEach-Object { gh pr view $_ --json body --jq '.body' | Select-String 'from\\s(\\d+).*to\\s(\\d+)' }"
    }
  ],
  "mcp": {
    "postgres": {
      "type": "local",
      "command": ["node", ".opencode\\postgres-wrapper.cjs"],
      "enabled": true,
      "timeout": 30000
    },
    "pinecone": {
      "type": "local",
      "command": ["node", ".opencode\\pinecone-wrapper.cjs"],
      "enabled": true,
      "timeout": 30000
    },
    "redis": {
      "type": "local",
      "command": ["node", ".opencode\\redis-wrapper.cjs"],
      "enabled": true,
      "timeout": 15000
    },
    "cloudflare": {
      "type": "local",
      "command": ["npx", "-y", "@cloudflare/mcp-server-cloudflare", "run", "6c77b8690fff1ed820e20271c8b40f5a"],
      "enabled": true,
      "timeout": 30000
    },
    "clerk": {
      "type": "remote",
      "url": "https://mcp.clerk.com/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:CLERK_SECRET_KEY}"
      }
    },
    "fetch": {
      "type": "local",
      "command": ["npx", "-y", "mcp-fetch-server"],
      "enabled": true,
      "timeout": 15000
    }
  }
}
