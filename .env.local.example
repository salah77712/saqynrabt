# ==============================================================================
# SAQYN RABT - ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================

# ------------------------------------------------------------------------------
# FRONTEND CONFIGURATION (Next.js 15)
# ------------------------------------------------------------------------------
# Clerk Publishable Key (from dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_***

# The external booking URL (defaults to Rule 18 sales-led booking URL)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/saqynrabt/demo

# URL of the Cloudflare Workers API backend
NEXT_PUBLIC_API_URL=https://api.saqynrabt.com

# ------------------------------------------------------------------------------
# BACKEND CONFIGURATION (Cloudflare Workers)
# ------------------------------------------------------------------------------
# Clerk Secret Key for JWT Validation
CLERK_SECRET_KEY=sk_test_***

# OpenAI API Key (gpt-4o-mini & text-embedding-3-small)
OPENAI_API_KEY=sk-proj-***

# Neon serverless PostgreSQL connection string (Rule 10)
DATABASE_URL=postgresql://user:password@ep-***.us-east-2.aws.neon.tech/neondb?sslmode=require

# Pinecone Vector database API key (Rule 20 / 34)
PINECONE_API_KEY=pcsk_***
PINECONE_INDEX_NAME=saqyn-rag

# Cloudflare R2 configurations for saqyn-documents bucket (Rule 24 / 37)
R2_ACCESS_KEY=***
R2_SECRET_KEY=***
R2_BUCKET_NAME=saqyn-documents

# Upstash Redis connection string for live balance caching (Rule 14)
REDIS_URL=redis://default:***@***.upstash.io:6379

# Voice AI Dead-Switch Toggle (Rule 32)
# Set strictly to "true" to activate the Voice dashboard flow
VOICE_AI_ACTIVATED="true"

# Vapi API key (from app.vapi.ai/settings/api-keys - Private Key)
VAPI_API_KEY=your_vapi_private_key_here
